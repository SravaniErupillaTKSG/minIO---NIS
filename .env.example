# ─── Application ───────────────────────────────────────────────────────────────
APP_ENV=development
APP_NAME=DMS Document Service
APP_VERSION=1.0.0
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=true

# ─── MinIO ─────────────────────────────────────────────────────────────────────
MINIO_ENDPOINT=localhost:9000
MINIO_ROOT_USER=your-minio-user
MINIO_ROOT_PASSWORD=your-minio-password
MINIO_SECURE=false

MINIO_BUCKET_CONTRIBUTORS=dms-contributors
MINIO_BUCKET_BENEFICIARIES=dms-beneficiaries
MINIO_BUCKET_EMPLOYEES=dms-employees
MINIO_BUCKET_TEMP=dms-temp

MINIO_PRESIGNED_EXPIRY=3600

# ─── Security ──────────────────────────────────────────────────────────────────
API_KEY=change-me
ALLOWED_ORIGINS=http://localhost:3000

# ─── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FILE=logs/dms.log
